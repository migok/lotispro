# ============================================
# LotisPro API - Environment Configuration
# ============================================
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env dans le contrôle de version !

# --------------------------------------------
# Application
# --------------------------------------------
APP_NAME=LotisPro API
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=production   # development | staging | production

# --------------------------------------------
# Sécurité
# --------------------------------------------
# Générer avec : openssl rand -hex 64
SECRET_KEY=your-super-secret-key-min-32-characters-change-me

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60   # 1 heure (recommandé en prod)

# --------------------------------------------
# Base de données — Supabase PostgreSQL
# --------------------------------------------
# Format Transaction Pooler (port 6543) — recommandé pour Railway/conteneurs
# Disponible dans : Supabase > Project Settings > Database > Connection Pooling
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Paramètres pool (adapter selon le plan Railway)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# --------------------------------------------
# CORS
# --------------------------------------------
# En production : domaine(s) Vercel uniquement
# Exemple : CORS_ORIGINS=["https://lotispro.vercel.app","https://www.lotispro.com"]
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
# Désactiver si derrière un reverse proxy (Railway / Cloudflare)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=WARNING   # DEBUG en dev, WARNING en prod
LOG_FORMAT=json     # json (prod) | console (dev)

# --------------------------------------------
# Super Admin — utilisé par scripts/create_admin.py au démarrage Railway
# --------------------------------------------
ADMIN_EMAIL=superadmin@example.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_NAME=Super Admin

# --------------------------------------------
# Supabase Storage (GeoJSON)
# Obligatoire uniquement si upload de fichiers GeoJSON activé
# --------------------------------------------
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=geojson-files

# --------------------------------------------
# Stockage fichiers locaux
# --------------------------------------------
DATA_DIR=./data
MAX_UPLOAD_SIZE_MB=10

# --------------------------------------------
# Email (Resend)
# --------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=LotisPro <noreply@yourdomain.com>
